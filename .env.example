# =============================================================================
# DM Toolkit — environment variable reference
#
# LOCAL DEV
#   Copy the relevant sections into backend/.env and frontend/.env.
#   The root .env is only used by Docker Compose to provision the MySQL
#   container; it is not read by the application at runtime.
#
# RAILWAY (PRODUCTION)
#   Variables marked [Railway: auto] are injected automatically by the
#   Railway MySQL plugin — do NOT set them manually in the Railway dashboard.
#   Variables marked [Railway: manual] must be added in the Railway service's
#   Variables panel.
# =============================================================================


# =============================================================================
# Docker Compose — MySQL container (local dev only, root .env)
# =============================================================================

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=dm_toolkit
MYSQL_USER=dm_user
MYSQL_PASSWORD=dm_password


# =============================================================================
# Backend (backend/.env for local dev, Railway Variables panel for production)
# =============================================================================

# --- Database ---

# Option A: single connection string (local dev default).
# In production Railway injects this automatically if you provision a MySQL
# plugin and enable "Share credentials as DATABASE_URL".
# [Railway: auto if DATABASE_URL sharing is enabled, otherwise auto via MYSQL* vars]
DATABASE_URL=mysql+pymysql://dm_user:dm_password@localhost:3306/dm_toolkit

# Option B: individual MySQL variables (injected automatically by Railway's
# MySQL plugin — no manual action needed on Railway).
# These are used by the app when DATABASE_URL is not set.
# [Railway: auto] — do not set manually in Railway
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=dm_user
MYSQLPASSWORD=dm_password
MYSQLDATABASE=dm_toolkit

# --- Auth ---

# Username and password for the single DM account.
# [Railway: manual]
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# [Railway: manual]
SECRET_KEY=change-this-to-a-long-random-secret-key

# How long a login token stays valid (minutes). Default: 480 (8 hours).
# [Railway: manual, optional]
ACCESS_TOKEN_EXPIRE_MINUTES=480


# =============================================================================
# Frontend (frontend/.env for local dev, set at build time for production)
# =============================================================================

# Full URL of the deployed backend API, no trailing slash.
# Local dev: point at the local uvicorn server.
# Railway: set to the public URL of the backend service, e.g.:
#   https://dm-toolkit-backend.up.railway.app
# [Railway: manual, required at build time]
VITE_API_URL=http://localhost:8000
