# Copy this to backend/.env and fill in real values for local dev.
# Never commit backend/.env to git.
# On Railway, set these in the dashboard under project → variables.
# DATABASE_URL is injected automatically by the Railway MySQL plugin —
# do not set it manually in Railway.

DATABASE_URL=mysql+pymysql://user:password@localhost:3306/dm_toolkit

# Used only on first startup to seed the initial user account.
# Once a user exists in the database these variables are ignored.
# On Railway: set in the dashboard, then remove after the first deploy.
INITIAL_USERNAME=admin
INITIAL_PASSWORD=changeme

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-with-python-c-"import-secrets;print(secrets.token_hex(32))"
ACCESS_TOKEN_EXPIRE_MINUTES=480
